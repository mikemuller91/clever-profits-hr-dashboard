# BambooHR API Configuration
# Get your API key from: BambooHR > Settings > API Keys
BAMBOO_API_KEY=your_api_key_here
BAMBOO_SUBDOMAIN=your_company_subdomain

# Anthropic API Key (for AI candidate evaluation)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Upstash Redis (REQUIRED for caching AI evaluations to avoid repeated API costs)
# Get your credentials from: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token
